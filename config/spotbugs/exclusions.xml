<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Records are transparent data carriers; EI/EI2 are false positives -->
    <Match>
        <Package name="scheduling.dto"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="scheduling.solver"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="scheduling.mapping"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="scheduling.model"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="scheduling.solver.mip.model"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
    <!--
      Main entry points intentionally keep a FileOutputStream open for the process lifetime
      to redirect console output; the OBL warning is a false positive here.
    -->
    <Match>
        <Class name="scheduling.MipMain"/>
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION"/>
    </Match>
    <Match>
        <Class name="scheduling.GraspMain"/>
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION"/>
    </Match>
    <Match>
        <Class name="scheduling.BeeColonyMain"/>
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION"/>
    </Match>
    <Match>
        <Class name="scheduling.RelaxedMIPMain"/>
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION"/>
    </Match>
</FindBugsFilter>
